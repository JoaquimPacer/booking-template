# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# playwright (e2e artifacts, not source)
/test-results
/playwright-report
/.playwright-mcp
/blob-report
/playwright/.cache

# local Sanity/DB backup snapshots (safety artifacts, not source)
/backups

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# editor-specific (Obsidian, JetBrains, etc.)
.obsidian/
.idea/

.vercel
.env*.local
