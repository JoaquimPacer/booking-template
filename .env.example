# Copy to .env for local dev (NOT .env.local — Prisma's CLI auto-reads .env, not .env.local).
# Both are gitignored. Set the same vars in Vercel project settings for staging/prod.

# === Database (Neon Postgres) ===
# Two connection strings per Neon branch. Get both from console.neon.tech > Branch > Connect.
# DATABASE_URL: POOLED connection (host contains "-pooler"). Used by Prisma client at runtime.
#   Vercel serverless functions need pooling or they exhaust Postgres's max connections.
# DIRECT_URL: DIRECT connection (host has no "-pooler"). Used only by `prisma migrate`.
#   Migrations need a direct connection because PgBouncer doesn't fully support the
#   prepared statements and long transactions migrate uses.
DATABASE_URL="postgresql://user:pass@host-pooler.region.aws.neon.tech/dbname?sslmode=require"
DIRECT_URL="postgresql://user:pass@host.region.aws.neon.tech/dbname?sslmode=require"

# === Sanity (hosted CMS) ===
# Get the project ID from sanity.io/manage after creating a project.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
# Business name shown in the Studio top-left (per client). Defaults to "Booking Template".
# Example: NEXT_PUBLIC_STUDIO_TITLE="Theresa Attea, LMT"
NEXT_PUBLIC_STUDIO_TITLE=
# Token used for server-side reads (ISR, draft mode). Create at sanity.io/manage > API > Tokens.
SANITY_API_READ_TOKEN=
# Editor-permission token used by scripts/replicate-prospect.ts to write content.
# Same Tokens page as above; choose "Editor" permission. Never expose in client code.
SANITY_API_WRITE_TOKEN=

# === NextAuth.js (admin / instructor login) ===
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# === Stripe (payments) ===
# Test keys for staging, live keys for production.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# === Resend (transactional email + .ics) ===
# Test sender = onboarding@resend.dev. Production needs verified domain (e.g. bookings@yourdomain.com).
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# === Twilio (SMS confirmations + reminders) ===
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Joaquim's verified toll-free number for production. Use a Twilio test number for dev.
TWILIO_PHONE_NUMBER=+18887940449

# === Google Calendar API ===
# Get from console.cloud.google.com > APIs & Services > Credentials > OAuth 2.0 Client IDs.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/oauth/callback

# === Studio singleton config (set per client deploy) ===
# IANA timezone string, e.g. America/Chicago, America/New_York.
STUDIO_TIMEZONE=America/Chicago
# Used in URLs and DB lookups; should match the Studio.slug row.
STUDIO_SLUG=demo

# === Google Places API (Phase 1.5: cold-call pitch funnel + reviews display) ===
# Used by scripts/replicate-prospect.ts to pull business data from Google.
# Get a key at console.cloud.google.com > APIs & Services > Credentials.
# Enable "Places API (New)". Restrict the key to that API only.
GOOGLE_PLACES_API_KEY=
