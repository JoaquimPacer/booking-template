# Copy to .env.local for local dev. Set the same vars in Vercel project settings for staging/prod.

# === Database (Neon Postgres) ===
# Get this from console.neon.tech after creating a project + branch.
DATABASE_URL="postgresql://user:pass@host/dbname?sslmode=require"

# === Sanity (hosted CMS) ===
# Get the project ID from sanity.io/manage after creating a project.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
# Token used for server-side reads (ISR, draft mode). Create at sanity.io/manage > API > Tokens.
SANITY_API_READ_TOKEN=

# === NextAuth.js (admin / instructor login) ===
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# === Stripe (payments) ===
# Test keys for staging, live keys for production.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# === Resend (transactional email + .ics) ===
# Test sender = onboarding@resend.dev. Production needs verified domain (e.g. bookings@yourdomain.com).
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# === Twilio (SMS confirmations + reminders) ===
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Joaquim's verified toll-free number for production. Use a Twilio test number for dev.
TWILIO_PHONE_NUMBER=+18887940449

# === Google Calendar API ===
# Get from console.cloud.google.com > APIs & Services > Credentials > OAuth 2.0 Client IDs.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/oauth/callback

# === Studio singleton config (set per client deploy) ===
# IANA timezone string, e.g. America/Chicago, America/New_York.
STUDIO_TIMEZONE=America/Chicago
# Used in URLs and DB lookups; should match the Studio.slug row.
STUDIO_SLUG=demo

# === Optional: Google Places API (for v1.5 rapid-replicate script + reviews display) ===
# GOOGLE_PLACES_API_KEY=
